{
  "name": "opendrone-web",
  "private": false,
  "sideEffects": false,
  "version": "2026.1.2",
  "type": "module",
  "license": "MIT",
  "homepage": "https://opendrone.be",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Just4Stan/OpenDrone-Web.git"
  },
  "bugs": {
    "url": "https://github.com/Just4Stan/OpenDrone-Web/issues"
  },
  "scripts": {
    "prebuild": "npm run sync:legal",
    "build": "shopify hydrogen build --codegen",
    "dev": "shopify hydrogen dev --codegen",
    "preview": "shopify hydrogen preview --build",
    "lint": "eslint --no-error-on-unmatched-pattern .",
    "typecheck": "react-router typegen && tsc --noEmit",
    "codegen": "shopify hydrogen codegen && react-router typegen",
    "sync:legal": "node scripts/sync-legal.mjs",
    "compose:newsletter": "node scripts/compose-newsletter.mjs",
    "gen:shopify-templates": "node scripts/shopify-templates/gen.mjs"
  },
  "prettier": "@shopify/prettier-config",
  "dependencies": {
    "@react-three/fiber": "^9.6.0",
    "@shopify/hydrogen": "^2026.4.1",
    "@tailwindcss/vite": "^4.2.2",
    "graphql": "^16.13.2",
    "isbot": "^5.1.39",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "7.14.2",
    "tailwindcss": "^4.2.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@graphql-codegen/cli": "^5.0.7",
    "@react-router/dev": "^7.14.2",
    "@react-router/fs-routes": "^7.14.2",
    "@shopify/cli": "^3.94.3",
    "@shopify/hydrogen-codegen": "^0.3.3",
    "@shopify/mini-oxygen": "^4.0.1",
    "@shopify/oxygen-workers-types": "^4.1.6",
    "@shopify/prettier-config": "^1.1.4",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/eslint": "^9.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "graphql-config": "^5.0.3",
    "prettier": "^3.8.3",
    "typescript": "^5.9.2",
    "vite": "^6.2.4",
    "vite-tsconfig-paths": "^4.3.1"
  },
  "engines": {
    "node": "^22 || ^24"
  }
}
