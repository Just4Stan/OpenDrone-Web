# Shopify Hydrogen — required environment variables
# Copy to .env and fill in values from your Shopify admin

# Random string used to sign session cookies
SESSION_SECRET="your-session-secret"

# Your myshopify.com domain (e.g. my-store.myshopify.com)
PUBLIC_STORE_DOMAIN=""

# Storefront API public access token (Headless channel → Storefront API)
PUBLIC_STOREFRONT_API_TOKEN=""

# Storefront ID shown in Hydrogen channel settings
PUBLIC_STOREFRONT_ID=""

# Customer Account API credentials (Settings → Customer accounts)
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
PUBLIC_CUSTOMER_ACCOUNT_API_URL=""

# Checkout domain (usually checkout.shopify.com or your custom domain)
PUBLIC_CHECKOUT_DOMAIN=""

# Private Storefront API token (server-side only, never expose to client)
PRIVATE_STOREFRONT_API_TOKEN=""

# Numeric Shop ID (used for analytics)
SHOP_ID=""

# Legal entity for footer, invoices, imprint, GPSR manufacturer block.
# Product branding stays OpenDrone/OpenFC/OpenESC — these describe the seller.
PUBLIC_COMPANY_NAME="Incutec BV"
PUBLIC_COMPANY_ADDRESS="Stapelhuisstraat 13, 3000 Leuven, Belgium"
PUBLIC_COMPANY_KBO="[pending]"
PUBLIC_COMPANY_VAT="BE[pending]"
PUBLIC_COMPANY_EMAIL="support@incutec.com"
PUBLIC_COMPANY_TEL="[pending]"

# Optional: override path to compliance Markdown source for `npm run sync:legal`.
# Defaults to ~/Library/.../incutec/compliance.
# COMPLIANCE_SRC=""
