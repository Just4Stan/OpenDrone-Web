# Shopify Hydrogen — environment variables
# Copy to .env and fill in values from Shopify admin before running `npm run dev`.

# ---------------------------------------------------------------------------
# Required — storefront cannot boot without these
# ---------------------------------------------------------------------------

# Random string used to sign session cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET="your-session-secret"

# Your myshopify.com domain (e.g. my-store.myshopify.com)
# Source: Shopify admin → Settings → Domains
PUBLIC_STORE_DOMAIN=""

# Storefront API public access token
# Source: Shopify admin → Sales channels → Headless → Storefront API
PUBLIC_STOREFRONT_API_TOKEN=""

# Private Storefront API token (server-side only, never expose to client)
# Source: same as above, Private token
PRIVATE_STOREFRONT_API_TOKEN=""

# Storefront ID shown in the Hydrogen sales channel settings
PUBLIC_STOREFRONT_ID=""

# Numeric Shop ID — used for Shopify analytics. Find via Storefront GraphQL:
#   query { shop { id } }   → gid://shopify/Shop/<NUM>
SHOP_ID=""

# Customer Account API credentials
# Source: Shopify admin → Settings → Customer accounts → Headless storefront
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
PUBLIC_CUSTOMER_ACCOUNT_API_URL=""

# ---------------------------------------------------------------------------
# Optional — falls back to PUBLIC_STORE_DOMAIN if unset
# ---------------------------------------------------------------------------

# Dedicated checkout subdomain (e.g. checkout.opendrone.eu). Defaults to
# PUBLIC_STORE_DOMAIN when empty.
PUBLIC_CHECKOUT_DOMAIN=""

# ---------------------------------------------------------------------------
# Legal entity — footer, imprint, invoices, GPSR manufacturer block.
# WER Art. VI.45 requires these to appear on every page of a BE webshop.
# ---------------------------------------------------------------------------
PUBLIC_COMPANY_NAME="Incutec BV"
PUBLIC_COMPANY_ADDRESS="Stapelhuisstraat 15, 3000 Leuven, Belgium"
PUBLIC_COMPANY_KBO="[pending]"      # BCE/KBO number — fill before launch
PUBLIC_COMPANY_VAT="BE[pending]"    # Same digits, BE-prefixed
PUBLIC_COMPANY_EMAIL="stan@incutec.eu"
PUBLIC_COMPANY_TEL="[pending]"      # Optional but recommended

# ---------------------------------------------------------------------------
# Compliance content sync (optional)
# ---------------------------------------------------------------------------
# Override path for `npm run sync:legal`. Defaults to the internal Incutec
# compliance workstream. sync:legal no-ops when the path is unreachable and
# preserves the committed snapshot under app/content/legal/.
# COMPLIANCE_SRC=""
