# Shopify Hydrogen — environment variables
# Copy to .env and fill in values from Shopify admin before running `npm run dev`.

# ---------------------------------------------------------------------------
# Required — storefront cannot boot without these
# ---------------------------------------------------------------------------

# Random string used to sign session cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET="your-session-secret"

# Your myshopify.com domain (e.g. my-store.myshopify.com)
# Source: Shopify admin → Settings → Domains
PUBLIC_STORE_DOMAIN=""

# Storefront API public access token
# Source: Shopify admin → Sales channels → Headless → Storefront API
PUBLIC_STOREFRONT_API_TOKEN=""

# Private Storefront API token (server-side only, never expose to client)
# Source: same as above, Private token
# Also used by the /newsletter action to enrol subscribers via Storefront
# API customerCreate with acceptsMarketing: true.
PRIVATE_STOREFRONT_API_TOKEN=""

# Storefront ID shown in the Hydrogen sales channel settings
PUBLIC_STOREFRONT_ID=""

# Numeric Shop ID — used for Shopify analytics. Find via Storefront GraphQL:
#   query { shop { id } }   → gid://shopify/Shop/<NUM>
SHOP_ID=""

# Customer Account API credentials
# Source: Shopify admin → Settings → Customer accounts → Headless storefront
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
PUBLIC_CUSTOMER_ACCOUNT_API_URL=""

# ---------------------------------------------------------------------------
# Optional — falls back to PUBLIC_STORE_DOMAIN if unset
# ---------------------------------------------------------------------------

# Dedicated checkout subdomain (e.g. checkout.opendrone.be). Defaults to
# PUBLIC_STORE_DOMAIN when empty.
PUBLIC_CHECKOUT_DOMAIN=""

# ---------------------------------------------------------------------------
# Legal entity — footer, imprint, invoices, GPSR manufacturer block.
# WER Art. VI.45 requires these to appear on every page of a BE webshop.
# ---------------------------------------------------------------------------
PUBLIC_COMPANY_NAME="Incutec BV"
PUBLIC_COMPANY_ADDRESS="Stapelhuisstraat 15, 3000 Leuven, Belgium"
PUBLIC_COMPANY_KBO="[pending]"      # BCE/KBO number — fill before launch
PUBLIC_COMPANY_VAT="BE[pending]"    # Same digits, BE-prefixed
PUBLIC_COMPANY_EMAIL="contact@opendrone.be"
PUBLIC_COMPANY_TEL="[pending]"      # Optional but recommended

# ---------------------------------------------------------------------------
# Compliance content sync (optional)
# ---------------------------------------------------------------------------
# Override path for `npm run sync:legal`. Defaults to the internal Incutec
# compliance workstream. sync:legal no-ops when the path is unreachable and
# preserves the committed snapshot under app/content/legal/.
# COMPLIANCE_SRC=""

# ---------------------------------------------------------------------------
# Web-support Discord bridge (optional)
# ---------------------------------------------------------------------------
# When DISCORD_BOT_TOKEN + DISCORD_SUPPORT_CHANNEL_ID are set, /contact
# renders a chat widget that creates a thread in the forum channel below.
# See app/lib/support/README.md for end-to-end setup.

# Discord bot token — keep as a secret, never public.
DISCORD_BOT_TOKEN=""

# Numeric ID of a **Forum** channel the bot can post threads in.
DISCORD_SUPPORT_CHANNEL_ID=""

# Server (guild) ID. Required for the Stage 2 moderation gate below —
# used to resolve which users carry the moderator role.
DISCORD_GUILD_ID=""

# Private staff-only channel for ticket metadata (email, Shopify
# customer id, IP hint, user-agent). When set, the public web-support
# forum thread shows only first-name + subject + message body, and the
# bot fires a companion message with the full PII + a jump-URL into
# THIS channel. Discord-side role permissions on this channel decide
# who can read it — give the same role that gates Stage 2 approvals
# View Channel, deny @everyone. Leave blank to keep the legacy
# "everything in the public thread" behaviour while you set up the
# private channel.
DISCORD_STAFF_METADATA_CHANNEL_ID=""

# Stage 2 moderation gate. When SUPPORT_MOD_ROLE_ID is set AND the
# mode below is "enforce", messages in a support thread only reach the
# customer once someone with that Discord role reacts with the approve
# emoji. Leave the role id blank to fall back to the legacy
# "relay everything" behaviour.
SUPPORT_MOD_ROLE_ID=""
# Approve emoji — default is ✅. Any unicode emoji works.
SUPPORT_APPROVE_EMOJI=""
# Gate behaviour. One of:
#   enforce  — only approved messages reach the customer (default once
#              SUPPORT_MOD_ROLE_ID is set).
#   log      — relay everything, log which messages *would* have been
#              held so staff can watch the gate before flipping on.
#   off      — gate fully disabled, no logging. Incident use only.
SUPPORT_MODERATION_MODE=""

# Invite link rendered on the contact page and inside the widget.
DISCORD_SUPPORT_INVITE="https://discord.gg/ABajnacUsS"

# Public-facing guild + invite for the rich /contact invite card. The
# loader hits GET /guilds/{id}?with_counts=true to render online +
# member counts and the description. PUBLIC_DISCORD_GUILD_ID falls back
# to DISCORD_GUILD_ID if unset; PUBLIC_DISCORD_INVITE falls back to
# DISCORD_SUPPORT_INVITE. Set both explicitly when the public card and
# the support bridge use different guilds (e.g. soft-launch / staging).
PUBLIC_DISCORD_GUILD_ID=""
PUBLIC_DISCORD_INVITE="https://discord.gg/ABajnacUsS"

# HMAC key for signing the support-session cookie. Generate with:
#   openssl rand -hex 32
# Falls back to SESSION_SECRET if unset.
SUPPORT_SESSION_SECRET=""

# Cloudflare Turnstile (optional but recommended) — site key is public,
# secret is server-only. Without these the intake form has no CAPTCHA.
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Local-dev-only escape hatch: set to "1" when you don't want to run
# Turnstile in development. Has no effect if TURNSTILE_SECRET_KEY is
# also set — it only kicks in when the secret is missing, which would
# otherwise fail closed in production. Never set this in Oxygen.
SUPPORT_TURNSTILE_DEV_SKIP=""

# Resend (transactional email). Powers the cross-device "resume by email"
# magic link sent on every new ticket, plus the consolidated ticket-list
# email when a returning user looks up their tickets. When unset, the
# rest of the bridge still works — users just don't get the resume link.
# Free tier: 3,000 emails/month. https://resend.com
RESEND_API_KEY=""
SUPPORT_FROM_EMAIL="support@opendrone.be"

# ---------------------------------------------------------------------------
# Stage 4 AI first-responder (optional)
# ---------------------------------------------------------------------------
# When enabled, every new ticket is routed through Claude to draft a
# reply. The draft is posted INTO THE DISCORD THREAD ONLY — the
# customer never sees it unless a moderator approves it with the
# Stage 2 approve emoji. Leaving SUPPORT_AI_DRAFTS_ENABLED blank
# (or the API key empty) keeps the AI path entirely off.
ANTHROPIC_API_KEY=""
SUPPORT_AI_DRAFTS_ENABLED=""
# Optional model override. Defaults to claude-haiku-4-5 (fast, cheap,
# right-sized for short support triage). Sonnet works if you want
# more nuanced drafts at higher cost.
SUPPORT_AI_MODEL=""
